FROM ubuntu:24.04

# Minimal install: only what claude needs
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
    && curl -fsSL https://cli.claude.ai/install.sh | sh \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Non-root user
RUN useradd -m -s /bin/bash claude
USER claude
WORKDIR /workspace

ENTRYPOINT ["claude"]
